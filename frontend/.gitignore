# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Playwright — transient per-run artifacts (traces, network logs, failure PNGs, reports).
# These regenerate on every e2e run and must never be committed (the standard Playwright
# convention). Does NOT touch e2e/*.spec sources or the *-snapshots/ baselines.
test-results/
playwright-report/
blob-report/
.playwright-artifacts-*/

# MeshClaw agent harness — the *.meshclaw.e2e.ts specs, their visual-snapshot
# baselines, captured screenshots, and the authenticated Playwright config are
# agent working files, local-only by design (NOT part of the product / not in CI).
e2e/*.meshclaw.e2e.ts
e2e/*.meshclaw.e2e.ts-snapshots/
e2e/__screenshots__/
playwright.meshclaw.config.ts
