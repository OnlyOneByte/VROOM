{
	"name": "vroom-frontend",
	"private": true,
	"version": "1.0.0",
	"description": "VROOM Car Tracker Frontend PWA",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest --run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:chromium": "playwright test --project=chromium",
		"test:e2e:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
		"generate-pwa-assets": "pwa-assets-generator",
		"lint": "eslint . --ext .js,.ts,.svelte",
		"lint:fix": "eslint . --ext .js,.ts,.svelte --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"type-check": "svelte-check --tsconfig ./tsconfig.json --threshold error",
		"all:fix": "npm run lint:fix && npm run format ",
		"validate": "npm run lint && npm run format:check && npm run type-check && npm run test"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^0.577.0",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.59.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/d3": "^7.4.3",
		"@types/jsdom": "^28.0.0",
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.18.2",
		"@vite-pwa/assets-generator": "^1.0.2",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@vitest/coverage-v8": "^4.1.5",
		"@vitest/ui": "^4.0.18",
		"autoprefixer": "^10.5.0",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"fast-check": "^4.7.0",
		"globals": "^17.6.0",
		"happy-dom": "^20.9.0",
		"jsdom": "^28.1.0",
		"layerchart": "^2.0.0-next.62",
		"mode-watcher": "^1.1.0",
		"postcss": "^8.5.14",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.7",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.10",
		"vitest": "^4.0.18"
	},
	"overrides": {
		"serialize-javascript": "^7.0.4"
	},
	"dependencies": {
		"@tailwindcss/postcss": "^4.2.4",
		"d3": "^7.9.0",
		"sveltekit-superforms": "^2.30.1",
		"zod": "^4.4.3"
	}
}
