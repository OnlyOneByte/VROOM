{
  "name": "vroom-backend",
  "version": "1.0.0",
  "description": "VROOM Car Tracker Backend API",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "dev:kill": "lsof -ti :3001 | xargs kill -9 2>/dev/null || echo 'No process on port 3001'",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "start": "bun dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:init": "bun src/db/init.ts",
    "db:seed": "bun src/db/init.ts --seed",
    "db:checkpoint": "bun src/db/checkpoint.ts",
    "db:checkpoint:force": "bun src/db/checkpoint.ts --force",
    "test": "bun test",
    "test:repositories": "bun src/test/run-tests.ts",
    "test:auth": "bun src/test/run-auth-tests.ts",
    "test:vehicles": "bun src/test/run-vehicle-tests.ts",
    "test:deployment": "bun src/test/run-deployment-tests.ts",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "check": "biome check src/",
    "check:fix": "biome check --write src/",
    "type-check": "tsc --noEmit",
    "all:fix": "bun run lint:fix && bun run format:fix && bun run check:fix",
    "validate": "bun run type-check && bun run check && bun test && bun run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@lucia-auth/adapter-drizzle": "^1.1.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "adm-zip": "^0.5.16",
    "arctic": "^3.7.0",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "googleapis": "^171.4.0",
    "hono": "^4.12.9",
    "lucia": "^3.2.2",
    "oslo": "^1.2.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "qs": "^6.15.0",
    "jws": "^4.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/adm-zip": "^0.5.8",
    "bun-types": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "fast-check": "^4.6.0",
    "typescript": "^5.9.3",
    "yaml": "^2.8.3"
  }
}