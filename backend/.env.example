# Environment Configuration
NODE_ENV=development
PORT=3001
HOST=localhost

# Database Configuration
DATABASE_URL=./data/vroom.db

# Google OAuth Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/auth/callback/google # used for login
GOOGLE_PROVIDER_REDIRECT_URI=http://localhost:3001/api/v1/auth/callback/provider/google # used for storage provider (drive)

# GitHub OAuth Configuration
# Get these from GitHub Developer Settings: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3001/api/v1/auth/callback/github

# Session Configuration
# Generate a secure random string (at least 32 characters)
# You can use: openssl rand -base64 32
SESSION_SECRET=your_super_secure_session_secret_here_at_least_32_chars

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:5173

# CORS Configuration (comma-separated origins)
# CORS_ORIGINS=http://localhost:5173,http://localhost:4173,https://yourdomain.com

# Logging Configuration
LOG_LEVEL=info

# Provider Credential Encryption
# 32-byte hex key for AES-256-GCM encryption of provider credentials
# Generate with: openssl rand -hex 32
PROVIDER_ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# Production Configuration (uncomment and configure for production)
# NODE_ENV=production
# PORT=3001
# HOST=0.0.0.0
# DATABASE_URL=/app/data/vroom.db
# FRONTEND_URL=https://yourdomain.com
# GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/callback/google
# CORS_ORIGINS=https://yourdomain.com
# LOG_LEVEL=warn