# Environment Configuration
NODE_ENV=development
PORT=3001
HOST=localhost

# Database Configuration
DATABASE_URL=./data/vroom.db

# Google OAuth Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/auth/callback/google # used for login
GOOGLE_PROVIDER_REDIRECT_URI=http://localhost:3001/api/v1/auth/callback/provider/google # used for storage provider (drive)

# GitHub OAuth Configuration
# Get these from GitHub Developer Settings: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3001/api/v1/auth/callback/github

# Session Configuration
# Generate a secure random string (at least 32 characters)
# You can use: openssl rand -base64 32
SESSION_SECRET=your_super_secure_session_secret_here_at_least_32_chars

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:5173

# CORS Configuration (comma-separated origins)
# CORS_ORIGINS=http://localhost:5173,http://localhost:4173,https://yourdomain.com

# Trusted reverse-proxy IPs (comma-separated). Rate limiting only honors the
# X-Forwarded-For header when the request's actual socket IP is in this list;
# otherwise the spoofable header is ignored and the real socket IP is used.
# Leave UNSET if VROOM is exposed directly (no proxy) — that's the safe default.
# Set to your load balancer / reverse proxy IP(s) when running behind one.
# TRUSTED_PROXY_IPS=10.0.0.1,10.0.0.2

# Logging Configuration
LOG_LEVEL=info

# Provider Credential Encryption
# 32-byte hex key for AES-256-GCM encryption of provider credentials
# Generate with: openssl rand -hex 32
PROVIDER_ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# Web Push (push notifications) — OPTIONAL. Leave unset to keep push OFF (the in-app
# reminder feed is unchanged). Generate a keypair with: bun run vapid:gen
# The PRIVATE key is a server secret (never shipped to the browser); the PUBLIC key is
# public-by-design. VAPID_SUBJECT is a mailto: or https: contact for the push service.
# VAPID_PUBLIC_KEY=your_vapid_public_key
# VAPID_PRIVATE_KEY=your_vapid_private_key
# VAPID_SUBJECT=mailto:you@example.com

# Production Configuration (uncomment and configure for production)
# NODE_ENV=production
# PORT=3001
# HOST=0.0.0.0
# DATABASE_URL=/app/data/vroom.db
# FRONTEND_URL=https://yourdomain.com
# GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/callback/google
# CORS_ORIGINS=https://yourdomain.com
# LOG_LEVEL=warn

# Local E2E harness flags (NEVER set in production — both are double-gated in config
# and refused when NODE_ENV=production). The regress.sh harness sets these inline.
# ALLOW_FAKE_STORAGE=1   # enable the in-memory FakeStorageProvider seam (no real OAuth)
# DISABLE_RATE_LIMIT=1   # bypass the in-memory rate limiter so the harness's own
#                        # request volume doesn't exhaust the window and 429 late specs