{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "--registry=https://registry.npmjs.org",
        "chrome-devtools-mcp@latest",
        "--browserUrl",
        "http://127.0.0.1:9222"
      ],
      "disabled": false,
      "autoApprove": [
        "take_screenshot",
        "navigate_page",
        "take_snapshot",
        "click",
        "list_console_messages",
        "emulate",
        "evaluate_script"
      ]
    }
  }
}